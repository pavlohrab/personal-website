---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Contact | Pavlo Hrab" description="Get in touch with Pavlo Hrab">
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="page-header with-action">
				<h1 class="page-title">Get in Touch</h1>
				<p class="page-subtitle">
					Open to conversations about computational biology roles, collaborations, and the tools I build.
					Email is the surest way to reach me.
				</p>
				<a href="mailto:contact@pavlohrab.com" class="btn btn-primary">
					Email Me
				</a>
			</header>

			<main class="contact-content">
				<section class="contact-info">
					<h2 class="section-title">Contact Information</h2>

					<div class="contact-grid">
						<div class="contact-card">
							<Icon icon="paper-plane-tilt" size="2em" />
							<h3>Email</h3>
							<a href="mailto:contact@pavlohrab.com" class="contact-link">
								contact[at]pavlohrab.com
							</a>
						</div>

						<div class="contact-card">
							<Icon icon="github-logo" size="2em" />
							<h3>GitHub</h3>
							<a href="https://github.com/pavlohrab" class="contact-link" target="_blank" rel="noopener">
								github.com/pavlohrab
							</a>
						</div>

						<div class="contact-card">
							<Icon icon="linkedin-logo" size="2em" />
							<h3>LinkedIn</h3>
							<a href="https://linkedin.com/in/phrab" class="contact-link" target="_blank" rel="noopener">
								linkedin.com/in/phrab
							</a>
						</div>

						<div class="contact-card">
							<Icon icon="orcid-logo" size="2em" />
							<h3>ORCID</h3>
							<a href="https://orcid.org/0000-0002-0742-8478" class="contact-link" target="_blank" rel="noopener">
								0000-0002-0742-8478
							</a>
						</div>

						<div class="contact-card">
							<Icon icon="scholar-logo" size="2em" />
							<h3>Google Scholar</h3>
							<a href="https://scholar.google.com/citations?user=VKJQl6UAAAAJ" class="contact-link" target="_blank" rel="noopener">
								View Profile
							</a>
						</div>

						<div class="contact-card">
							<Icon icon="researchgate-logo" size="2em" />
							<h3>ResearchGate</h3>
							<a href="https://researchgate.net/profile/Pavlo-Hrab-2" class="contact-link" target="_blank" rel="noopener">
								View Profile
							</a>
						</div>
					</div>
				</section>

				<section class="location-section">
					<h2 class="section-title">Location</h2>
					<div class="location-card">
						<p class="location-text">
							<strong>Wageningen, the Netherlands</strong><br/>
							Bioinformatics Group, Wageningen University & Research
						</p>
					</div>
				</section>

				<section class="message-section">
					<h2 class="section-title">What I'm open to</h2>
					<div class="message-card">
						<p>
							<strong>Computational biology roles.</strong> Pipelines and tooling, multi-omics analysis,
							genome mining — in industry or in research.
						</p>
						<p>
							<strong>Questions about the tools.</strong> If something I have written is useful to you, or
							nearly does what you need and doesn't, tell me. Issues and feature requests are welcome on
							GitHub, or by email if that is easier.
						</p>
						<p>
							<strong>Collaborations.</strong> Microbiome bioinformatics, natural product discovery, and
							anything that needs both a command line and a lab bench.
						</p>
						<p class="response-time">I usually reply within a few days.</p>
					</div>
				</section>
			</main>
		</div>
	</div>
</BaseLayout>

<style>
	.contact-content {
		max-width: var(--width-content);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.contact-card {
		padding: 2rem;
		background: var(--gray-999);
		border-radius: var(--radius-surface);
		border-top: var(--accent-bar) solid var(--accent-regular);
		box-shadow: var(--shadow-sm);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
	}

	.contact-card h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin: 0;
	}

	.contact-link {
		color: var(--gray-300);
		text-decoration: none;
		font-size: var(--text-base);
		word-break: break-all;
		/* background-size must stay in the transition or the sweep snaps
		   instead of sweeping — the shorthand replaces the one on `a`. */
		transition:
			color var(--theme-transition),
			background-size var(--sweep);
	}

	.contact-link:hover {
		color: var(--accent-regular);
	}

	.location-card {
		max-width: 40rem;
		margin-inline: auto;
		padding: 2rem;
		background: var(--gray-999);
		border-radius: var(--radius-surface);
		border-left: var(--accent-bar) solid var(--accent-regular);
		box-shadow: var(--shadow-sm);
		text-align: center;
	}

	.location-text {
		font-size: var(--text-base);
		color: var(--gray-300);
		line-height: 1.8;
		margin: 0;
	}

	.location-text strong {
		color: var(--gray-0);
		font-size: var(--text-lg);
	}

	.message-section {
		margin-bottom: 2rem;
	}

	.message-card {
		max-width: 50rem;
		margin-inline: auto;
		padding: 2rem;
		background: var(--gray-999);
		border-radius: var(--radius-surface);
		border-left: var(--accent-bar) solid var(--accent-regular);
		box-shadow: var(--shadow-sm);
	}

	.message-card p {
		font-size: var(--text-base);
		color: var(--gray-300);
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.message-card p:last-of-type {
		margin-bottom: 0;
	}

	.message-card ul {
		margin: 1rem 0 1rem 1.5rem;
		color: var(--gray-300);
		line-height: 1.8;
	}

	.message-card li {
		margin-bottom: 0.5rem;
	}

	@media (max-width: 50em) {
				.contact-grid {
			grid-template-columns: 1fr;
		}

		.contact-card {
			padding: 1.5rem;
		}
	}

	.response-time {
		color: var(--gray-400);
		font-size: var(--text-sm);
	}
</style>
