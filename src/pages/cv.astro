<script>
	// Everything here re-runs on astro:page-load. With View Transitions a page's
	// module script does NOT re-execute on client-side navigation, and `window
	// load` never fires again — which is why the TOC toggle was dead and the
	// scroll spy never lit up when you arrived at /cv/ from another page.
	function initCv() {
		const tocNav = document.getElementById('toc-nav');
		const tocToggle = document.getElementById('toc-toggle');
		if (!tocNav) return;

		/* ---------- mobile: Jump to section ---------- */
		if (tocToggle && !tocToggle.dataset.bound) {
			tocToggle.dataset.bound = 'true';
			const icon = tocToggle.querySelector('.toggle-icon');
			const setOpen = (open: boolean) => {
				tocNav.classList.toggle('toc-expanded', open);
				tocToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
				if (icon) icon.textContent = open ? '▲' : '▼';
			};
			setOpen(false);
			tocToggle.addEventListener('click', () => {
				setOpen(!tocNav.classList.contains('toc-expanded'));
			});
		}

		/* ---------- smooth scroll + close the mobile menu ---------- */
		const links = Array.from(
			document.querySelectorAll<HTMLAnchorElement>('.toc-link')
		);
		for (const link of links) {
			if (link.dataset.bound) continue;
			link.dataset.bound = 'true';
			link.addEventListener('click', e => {
				const id = link.getAttribute('href');
				if (!id || !id.startsWith('#')) return;
				const target = document.querySelector(id);
				if (!target) return;
				e.preventDefault();
				tocNav.classList.remove('toc-expanded');
				const icon = tocToggle?.querySelector('.toggle-icon');
				if (icon) icon.textContent = '▼';
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
				history.replaceState(null, '', id);
			});
		}

		/* ---------- scroll spy ----------
		   An IntersectionObserver, not offsetTop arithmetic: offsetTop is measured
		   against the nearest positioned ancestor, so the old comparison against
		   window.pageYOffset was wrong the moment the layout changed. */
		const sections = Array.from(document.querySelectorAll('.cv-section'));
		if (!sections.length) return;

		const visible = new Set<string>();

		const setActive = (id: string) => {
			for (const link of links) {
				link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
			}
		};

		const observer = new IntersectionObserver(
			entries => {
				for (const entry of entries) {
					const id = entry.target.id;
					if (entry.isIntersecting) visible.add(id);
					else visible.delete(id);
				}
				// Highlight the topmost section currently on screen.
				const first = sections.find(sec => visible.has(sec.id));
				if (first) setActive(first.id);
			},
			{
				// A band across the upper part of the viewport: a section counts as
				// "current" once its top reaches roughly a quarter down the screen.
				rootMargin: '-25% 0px -60% 0px',
				threshold: 0,
			}
		);

		for (const sec of sections) observer.observe(sec);

		// Something must be lit before the first scroll event.
		setActive(sections[0].id);

		document.addEventListener('astro:before-swap', () => observer.disconnect(), {
			once: true,
		});
	}

	/* ---------- mobile: collapse long content behind "Read more" ---------- */
	function initReadMore() {
		const isMobile = window.matchMedia('(max-width: 50em)').matches;
		const existing = document.querySelectorAll('.read-more-btn');

		if (!isMobile) {
			existing.forEach(btn => btn.remove());
			document
				.querySelectorAll<HTMLElement>('.entry-list, .software-body, .profile-more')
				.forEach(el => {
					el.classList.remove('expanded', 'is-collapsible');
					el.style.maxHeight = '';
					el.style.opacity = '';
					el.style.transitionDuration = '';
				});
			return;
		}
		if (existing.length > 0) return;

		const collapsibles = document.querySelectorAll(
			'.entry-list, .software-body, .profile-more'
		);

		collapsibles.forEach(el => {
			const block = el as HTMLElement;
			const btn = document.createElement('span');
			btn.className = 'read-more-btn';
			btn.textContent = 'Read more';
			btn.setAttribute('role', 'button');
			btn.setAttribute('tabindex', '0');
			btn.setAttribute('aria-expanded', 'false');

			block.parentNode?.insertBefore(btn, block.nextSibling);

			// JS owns the collapse from here.
			block.classList.add('is-collapsible');
			block.style.maxHeight = '0px';
			block.style.opacity = '0';

			// Travel time should follow travel distance. A flat 300ms makes a
			// 1400px expansion feel like a snap and a 160px one feel sluggish.
			const duration = (h: number) =>
				`${Math.min(700, Math.max(300, Math.round(280 + h * 0.28)))}ms`;

			const toggle = () => {
				const open = !block.classList.contains('expanded');
				block.classList.toggle('expanded', open);
				btn.classList.toggle('expanded', open);
				btn.textContent = open ? 'Show less' : 'Read more';
				btn.setAttribute('aria-expanded', open ? 'true' : 'false');

				if (open) {
					// Animate to the content's true height, then release the cap
					// entirely so nothing can ever be clipped — however long the
					// bullets get, and however the text reflows afterwards.
					const h = block.scrollHeight;
					block.style.transitionDuration = duration(h);
					block.style.maxHeight = `${h}px`;
					block.style.opacity = '1';
					block.addEventListener('transitionend', function done(e) {
						// opacity finishes too; only the height transition means "done".
						if ((e as TransitionEvent).propertyName !== 'max-height') return;
						block.style.maxHeight = 'none';
						block.removeEventListener('transitionend', done);
					});
				} else {
					// max-height is 'none' at this point, and you cannot animate
					// from 'none'. Pin it to the measured height, force a reflow,
					// then collapse.
					const h = block.scrollHeight;
					block.style.transitionDuration = duration(h);
					block.style.maxHeight = `${h}px`;
					void block.offsetHeight;
					block.style.maxHeight = '0px';
					block.style.opacity = '0';

					// Collapsing removes the block's height from ABOVE the reader's
					// scroll position, so everything below shifts up by that much
					// and they are left stranded near the end of the page. Bring the
					// item they just collapsed back into view — but only if it has
					// actually scrolled off the top, so collapsing something already
					// on screen doesn't yank the page around.
					const anchor =
						block.closest('.cv-entry') ?? block.closest('.cv-section') ?? block;
					if (anchor.getBoundingClientRect().top < 0) {
						anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}
				}
			};

			btn.addEventListener('click', toggle);
			btn.addEventListener('keydown', e => {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					toggle();
				}
			});
		});
	}

	function init() {
		initCv();
		initReadMore();
	}

	document.addEventListener('astro:page-load', init);
	window.addEventListener('resize', initReadMore);
	init();
</script>

