---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// ---------------------------------------------------------------------------
// Selected Software — edit these two lists to choose which tools the CV shows,
// and in what order. The Tools page still lists everything; this is the cut.
//
// Wording, stack, signals and links are still read from src/content/tools/, so
// each tool is described in exactly one place. Only the *selection* lives here.
//
// Available: ashelper, mag-cleaning-pipeline, bgcviz, pfam-tools,
//            bigscape-pfam-explorer, rrnadif, hrmr, metawrap, arrower
// ---------------------------------------------------------------------------
const SELECTED = ['ashelper', 'mag-cleaning-pipeline', 'bgcviz', 'pfam-tools'];
const SELECTED_CONTRIBUTIONS = ['metawrap', 'arrower'];

const allTools = await getCollection('tools');

/** Look tools up by slug, in the order listed. Fails the build on a typo. */
function pick(slugs: string[]) {
	return slugs.map(slug => {
		const tool = allTools.find(t => t.id === slug);
		if (!tool) {
			throw new Error(
				`cv.astro: no tool "${slug}" in src/content/tools/. ` +
					`Available: ${allTools.map(t => t.id).join(', ')}`
			);
		}
		return tool;
	});
}

const tools = pick(SELECTED);
const contributions = pick(SELECTED_CONTRIBUTIONS);

// ---------------------------------------------------------------------------
// Related work — what each CV entry actually produced.
//
// This is what a CV on the web can do that a PDF cannot: turn "built a Nextflow
// pipeline that cleaned 19,720 genomes" from a claim into a click. Deliberately
// a row of links UNDER each entry rather than links inside the bullets — a
// bullet peppered with links stops being scannable, and a CV lives or dies on
// scannability.
//
// Slugs only. Titles and URLs are resolved from the collections, so they cannot
// drift, and a typo fails the build instead of shipping a dead link.
// NOTE: `bgcviz` and `rrnadif` exist in BOTH collections, hence the split.
// ---------------------------------------------------------------------------
const RELATED: Record<string, { projects?: string[]; tools?: string[] }> = {
	// Nothing published from the postdoc yet — add slugs here when there is.
	postdoc: {},
	phd: {
		projects: ['acido_biosynhtetic_potential', 'marine-acido-host', 'bacteria_cultivation'],
		tools: ['mag-cleaning-pipeline', 'ashelper', 'bigscape-pfam-explorer', 'pfam-tools'],
	},
	labtech: {
		tools: ['rrnadif', 'bgcviz'],
	},
};

const allProjects = await getCollection('projects');

function relatedFor(key: string) {
	const spec = RELATED[key] ?? {};
	const out: { title: string; href: string }[] = [];

	for (const slug of spec.projects ?? []) {
		const project = allProjects.find(x => x.id === slug);
		if (!project) {
			throw new Error(
				`cv.astro: RELATED.${key} references project "${slug}", which does not ` +
					`exist. Available: ${allProjects.map(x => x.id).join(', ')}`
			);
		}
		out.push({ title: project.data.title, href: `/projects/${project.id}/` });
	}

	for (const slug of spec.tools ?? []) {
		const tool = allTools.find(x => x.id === slug);
		if (!tool) {
			throw new Error(
				`cv.astro: RELATED.${key} references tool "${slug}", which does not exist. ` +
					`Available: ${allTools.map(x => x.id).join(', ')}`
			);
		}
		// Tools have no page of their own; the cards on /tools/ are anchor targets.
		out.push({ title: tool.data.title, href: `/tools/#${tool.id}` });
	}

	return out;
}
