---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Grid from '../components/Grid.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';

const allTools = (await getCollection('tools'))
	.filter(t => !t.data.draft)
	.sort((a, b) => a.data.order - b.data.order);

const authored = allTools.filter(t => t.data.role === 'author');
const contributed = allTools.filter(t => t.data.role === 'contributor');

// Resolve the project each tool came out of, so cards can link back to it.
const projectTitles = new Map<string, string>();
for (const tool of allTools) {
	if (!tool.data.project) continue;
	const project = await getEntry('projects', tool.data.project);
	if (project) projectTitles.set(tool.data.project, project.data.title);
}
---

<BaseLayout
	title="Tools"
	description="Open-source tools and pipelines for microbial genomics: Nextflow pipelines, Python packages, and R/Shiny apps."
>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="page-header">
				<h1 class="page-title">Tools</h1>
				<p class="page-subtitle">
					Open-source software I have built for microbial genomics — pipelines, packages, and apps.
					Everything here is on GitHub and documented.
				</p>
			</header>

			<main class="projects-content stack gap-15 lg:gap-20">
				<Section>
					<SectionHeader title="Software" />
					<Grid variant="projects">
						{authored.map(tool => (
							<article class="project-card tool-card">
								{tool.data.image && (
									<div class="tool-figure">
										<img
											src={tool.data.image}
											alt={tool.data.imageAlt ?? tool.data.title}
											loading="lazy"
										/>
									</div>
								)}

								<div class="project-header">
									<h3 class="project-title mono">{tool.data.title}</h3>
									<span class="project-meta tool-year">{tool.data.year}</span>
								</div>

								<p class="project-description">{tool.data.description}</p>

								{tool.data.signals.length > 0 && (
									<div class="tool-signals">
										{tool.data.signals.map(signal => (
											<span class="signal">{signal}</span>
										))}
									</div>
								)}

								<p class="tool-stack">{tool.data.stack.join(' · ')}</p>

								{tool.data.project && projectTitles.has(tool.data.project) && (
									<p class="tool-origin">
										Built for{' '}
										<a href={`/projects/${tool.data.project}/`}>
											{projectTitles.get(tool.data.project)}
										</a>
									</p>
								)}

								<div class="project-links">
									{tool.data.links.map(link => (
										<a href={link.href} class="project-link" target="_blank" rel="noopener">
											{link.label}
										</a>
									))}
								</div>
							</article>
						))}
					</Grid>
				</Section>

				{contributed.length > 0 && (
					<Section>
						<SectionHeader title="Contributions" />
						<Grid variant="projects-compact">
							{contributed.map(tool => (
								<article class="project-card compact tool-card contribution">
									<div class="project-header">
										<h3 class="project-title mono">{tool.data.title}</h3>
										<span class="project-meta tool-year">{tool.data.year}</span>
									</div>
									<p class="project-description">{tool.data.description}</p>
									<p class="tool-stack">{tool.data.stack.join(' · ')}</p>
									<div class="project-links">
										{tool.data.links.map(link => (
											<a href={link.href} class="project-link" target="_blank" rel="noopener">
												{link.label}
											</a>
										))}
									</div>
								</article>
							))}
						</Grid>
					</Section>
				)}
			</main>
		</div>
	</div>
</BaseLayout>

<style>
	/* Tool cards reuse the project-card chrome; these are the tool-only additions. */
	.tool-card :global(.project-title.mono) {
		font-family: var(--font-brand);
	}

	/* Tool cards are static: the links inside them are the interactive part.
	   Per the site rule, a surface that does not navigate does not lift. */
	.tool-card:hover {
		transform: none;
		box-shadow: var(--shadow-sm);
	}

	.tool-card.contribution {
		border-top-color: var(--gray-600);
	}

	.tool-figure {
		margin: -2rem -2rem 1.5rem;
		border-radius: var(--radius-surface) var(--radius-surface) 0 0;
		overflow: hidden;
		background: var(--gray-900);
		border-bottom: 1px solid var(--gray-800);
	}

	.tool-figure img {
		display: block;
		width: 100%;
		height: 12rem;
		object-fit: cover;
		object-position: center top;
	}

	.tool-signals {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-bottom: 1rem;
	}

	.signal {
		display: inline-block;
		padding: 0.2rem 0.6rem;
		border-radius: var(--radius-pill);
		font-size: var(--text-xs);
		font-weight: 600;
		letter-spacing: 0.02em;
		color: var(--accent-text-over);
		background: var(--accent-regular);
	}

	.tool-year {
		margin: 0;
		white-space: nowrap;
	}

	.tool-stack {
		font-family: var(--font-brand);
		font-size: var(--text-xs);
		color: var(--gray-400);
		margin: 0 0 1.25rem;
		line-height: 1.5;
	}

	.tool-origin {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0 0 1.25rem;
	}

	.tool-origin a {
		color: var(--gray-300);
	}
</style>
